{
  "name": "office-addin",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.25.0",
  "scripts": {
    "dev": "pnpm i18n:compile && vite --host",
    "dev:linked": "pnpm i18n:compile && vite --host --mode linked",
    "dev:with-library": "uv run --script scripts/dev.py",
    "dev:with-library:linked": "uv run --script scripts/dev.py --mode linked",
    "build": "pnpm i18n:compile && tsc && vite build && node scripts/copy-runtime-manifest.mjs",
    "check": "pnpm run format:check && pnpm run lint:strict && pnpm run typecheck",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "i18n:extract": "lingui extract",
    "i18n:extract:check": "./scripts/check-i18n-extract.sh",
    "i18n:compile": "lingui compile",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:strict": "eslint . --max-warnings=0",
    "preview": "vite preview",
    "office:validate": "office-addin-manifest validate manifests/manifest.xml",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@azure/msal-browser": "^5.2.0",
    "@azure/msal-common": "^16.2.0",
    "@erato/frontend": "file:../frontend/dist-package/erato-frontend.tgz",
    "@lingui/core": "5.9.4",
    "@lingui/react": "5.9.4",
    "@remix-run/router": "1.23.2",
    "@tanstack/query-core": "5.75.7",
    "@tanstack/query-sync-storage-persister": "5.69.0",
    "@tanstack/react-query": "5.75.7",
    "@tanstack/react-query-devtools": "5.75.7",
    "@tanstack/react-query-persist-client": "5.75.7",
    "postal-mime": "2.7.4",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-router": "6.30.3",
    "react-router-dom": "^6.25.1",
    "scheduler": "^0.27.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@eslint/js": "^9.28.0",
    "@lingui/babel-plugin-lingui-macro": "^5.9.4",
    "@lingui/cli": "^5.9.4",
    "@lingui/vite-plugin": "^5.9.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/office-js": "^1.0.571",
    "@types/react": "19.0.8",
    "@types/react-dom": "19.0.3",
    "@typescript-eslint/eslint-plugin": "^8.26.0",
    "@typescript-eslint/parser": "^8.26.0",
    "@vitejs/plugin-react": "^4.3.1",
    "eslint": "^9",
    "eslint-import-resolver-typescript": "^4.4.3",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-lingui": "^0.10.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "jsdom": "^29.0.1",
    "office-addin-manifest": "^2.1.2",
    "prettier": "3.5.0",
    "typescript": "^5",
    "vite": "^6.0.0",
    "vite-plugin-mkcert": "^1.17.9",
    "vitest": "^4.1.2"
  }
}
