{
  "name": "@erato/frontend",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.25.0",
  "files": [
    "dist-library"
  ],
  "exports": {
    "./library": {
      "types": "./dist-library/library/index.d.ts",
      "import": "./dist-library/library.js"
    },
    "./library.css": "./dist-library/style.css"
  },
  "scripts": {
    "dev": "pnpm i18n:compile && vite",
    "build": "pnpm build:app",
    "build:app": "pnpm i18n:compile && tsc && vite build",
    "build:lib": "tsc -p tsconfig.lib.json && node scripts/rewrite-library-dts-paths.mjs && vite build --config vite.library.config.ts --mode library && node scripts/pack-library.mjs",
    "build:lib:watch": "node scripts/watch-library.mjs",
    "pack:lib": "node scripts/pack-library.mjs",
    "start": "vite preview",
    "lint": "eslint .",
    "lint:strict": "eslint --max-warnings=0 .",
    "lint:fix": "eslint --fix .",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "coverage": "vitest run --coverage",
    "codegen:generate": "openapi-codegen gen v1betaApi",
    "codegen:fix-types": "node scripts/fix-codegen-types.mjs",
    "codegen": "pnpm codegen:generate && pnpm codegen:fix-types",
    "typecheck": "tsc --noEmit",
    "check": "pnpm lint:strict && pnpm typecheck",
    "i18n:extract": "lingui extract",
    "i18n:extract:clean": "lingui extract --clean",
    "i18n:extract:check": "./scripts/check-i18n-extract.sh",
    "i18n:compile": "lingui compile",
    "i18n:watch": "lingui extract --watch"
  },
  "dependencies": {
    "@lingui/detect-locale": "^5.9.4",
    "@lingui/format-po": "^5.9.4",
    "@react-hook/resize-observer": "^2.0.2",
    "@types/react-syntax-highlighter": "^15.5.13",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "eslint-plugin-tailwindcss": "^3.18.0",
    "fuse.js": "^7.1.0",
    "iconoir-react": "^7.11.0",
    "immer": "^10.1.1",
    "lodash": "^4.17.21",
    "non.geist": "^1.0.4",
    "react-dropzone": "^14.3.8",
    "react-error-boundary": "^5.0.0",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^15.6.1",
    "react-use": "^17.6.0",
    "react-window": "^1.8.11",
    "remark-gfm": "^4.0.1",
    "simple-icons": "^16.13.0",
    "sse.js": "^2.5.0",
    "use-debounce": "^10.0.4",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@babel/core": "^7.26.10",
    "@chromatic-com/storybook": "^3.2.4",
    "@eslint/eslintrc": "^3",
    "@eslint/js": "^9.28.0",
    "@faker-js/faker": "^9.4.0",
    "@lingui/babel-plugin-lingui-macro": "^5.9.4",
    "@lingui/cli": "^5.9.4",
    "@lingui/core": "5.9.4",
    "@lingui/message-utils": "^5.9.4",
    "@lingui/react": "5.9.4",
    "@lingui/vite-plugin": "^5.9.4",
    "@openapi-codegen/cli": "^3.1.0",
    "@openapi-codegen/typescript": "^11.0.1",
    "@storybook/addon-a11y": "^8.6.14",
    "@storybook/addon-actions": "^8.6.14",
    "@storybook/addon-essentials": "^8.6.14",
    "@storybook/addon-interactions": "^8.6.14",
    "@storybook/addon-onboarding": "^8.6.14",
    "@storybook/addon-storysource": "^8.6.14",
    "@storybook/addon-themes": "^8.6.14",
    "@storybook/blocks": "^8.6.14",
    "@storybook/react": "^8.6.14",
    "@storybook/react-vite": "^8.6.14",
    "@storybook/test": "^8.6.14",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@types/jest": "^29.5.14",
    "@types/lodash": "^4.17.16",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/react-window": "^1.8.8",
    "@typescript-eslint/eslint-plugin": "^8.26.0",
    "@typescript-eslint/parser": "^8.26.0",
    "@vitejs/plugin-react": "^4.3.1",
    "@vitest/coverage-v8": "^3.2.3",
    "eslint": "^9",
    "eslint-import-resolver-typescript": "^4.4.3",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-lingui": "^0.10.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-storybook": "^0.11.2",
    "jsdom": "^26.0.0",
    "msw": "^2.7.3",
    "postcss": "^8",
    "prettier": "3.5.0",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-router": "6.30.3",
    "react-router-dom": "6.30.3",
    "storybook": "^8.6.14",
    "tailwindcss": "^3.4.1",
    "typescript": "^5",
    "vite": "^6.0.0",
    "vitest": "^3.2.3"
  },
  "peerDependencies": {
    "@lingui/core": "^5.9.4",
    "@lingui/react": "^5.9.4",
    "@tanstack/query-core": "5.75.7",
    "@tanstack/query-sync-storage-persister": "5.69.0",
    "@tanstack/react-query": "5.75.7",
    "@tanstack/react-query-devtools": "5.75.7",
    "@tanstack/react-query-persist-client": "5.75.7",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router": "6.30.3",
    "react-router-dom": "6.30.3"
  },
  "eslintConfig": {
    "extends": [
      "plugin:storybook/recommended"
    ]
  }
}
