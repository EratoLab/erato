{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://schemas.erato.ai/desktop-sidecar/v1/common.schema.json",
  "title": "CommonProtocolTypes",
  "definitions": {
    "ProtocolVersion": {
      "type": "string",
      "pattern": "^[1-9][0-9]*\\.[0-9]+$"
    },
    "RequestId": {
      "oneOf": [
        { "type": "string", "minLength": 1, "maxLength": 128 },
        { "type": "integer" }
      ]
    },
    "Digest": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "Revision": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "ProductInfo": {
      "type": "object",
      "required": ["name", "version"],
      "properties": {
        "name": { "type": "string", "minLength": 1, "maxLength": 128 },
        "version": { "type": "string", "minLength": 1, "maxLength": 128 }
      },
      "additionalProperties": true
    },
    "CatalogueIdentity": {
      "type": "object",
      "required": ["revision", "digest"],
      "properties": {
        "revision": { "$ref": "#/definitions/Revision" },
        "digest": { "$ref": "#/definitions/Digest" }
      },
      "additionalProperties": true
    }
  }
}
