default:
  just --list

install:
    pnpm install

# Check all prerequisites before running tests
[no-exit-message]
check:
    ./scripts/check_prerequisites.sh

# Check configuration alignment using Claude Code (requires claude CLI)
[no-exit-message]
check-config:
    ./scripts/check_config_alignment.sh

# Generate required test files
generate-test-files:
    ./scripts/generate_test_files.sh

# Generate N long+bloated PDFs in test-files/<subdir>
generate-long-bloated-files count='20' subdir='long-bloated-files' words='10000' size_mb='19':
    ./scripts/generate_long_bloated_pdfs.py --count {{count}} --subdir {{subdir}} --words {{words}} --size-mb {{size_mb}}

# Run tests (checks prerequisites first)
test: check
    pnpm exec playwright test

# Opens the Playwright test runner UI
test_interactive: check
    pnpm exec playwright test --ui

# Opens the Playwright recorder
record_interactions: check
    pnpm exec playwright codegen

format:
    pnpm exec prettier . --write

check-format:
    pnpm exec prettier . --check
